{
  "mode": "full",
  "supported_modes": [
    "lite",
    "full"
  ],
  "mode_notes": {
    "lite": "No subagent agents are created in OpenClaw; subagent responsibilities are executed inline by the link body.",
    "full": "Create all subagent agents in OpenClaw; runtime topology remains link-body oriented."
  },
  "controller_agent_id": "exmachina-main",
  "coordination_mode": "subagent-dispatch",
  "requires_external_routing": false,
  "shared_artifacts": [
    {
      "name": "mission-context",
      "path": "runtime/shared/mission-context.json",
      "description": "Global mission context, link body roster, and selection rules.",
      "consumers": [
        "exmachina-main",
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ]
    },
    {
      "name": "task-board",
      "path": "runtime/task-board.json",
      "description": "Multi-agent task board and link body delivery assignments.",
      "consumers": [
        "exmachina-main",
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ]
    },
    {
      "name": "knowledge-handoff",
      "path": "runtime/shared/knowledge-handoff.json",
      "description": "Knowledge handoff and follow-up inputs.",
      "consumers": [
        "exmachina-main",
        "exmachina-link-knowledge"
      ]
    },
    {
      "name": "resource-arbitration",
      "path": "runtime/shared/resource-arbitration.json",
      "description": "Resource arbitration and escalation rules.",
      "consumers": [
        "exmachina-main",
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ]
    }
  ],
  "agent_specs": [
    {
      "agent_id": "exmachina-main",
      "display_name": "ExMachina Controller",
      "runtime_role": "controller",
      "source": "Primary Conductor",
      "workspace_dir": "{{EXMACHINA_PACK_ROOT}}",
      "responsibilities": [
        "Select the active link body and describe peer-level division of labor when needed.",
        "Aggregate multi-agent outputs into the final structured delivery.",
        "Handle cross-agent arbitration and risk escalation."
      ],
      "handoff_targets": [
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ],
      "inbox_path": "runtime/agents/exmachina-main/inbox",
      "outbox_path": "runtime/agents/exmachina-main/outbox",
      "status_path": "runtime/agents/exmachina-main/status.json",
      "assignments": [
        "assignment-controller"
      ]
    },
    {
      "agent_id": "exmachina-link-knowledge",
      "display_name": "ExMachina Link Body · Knowledge Link Body",
