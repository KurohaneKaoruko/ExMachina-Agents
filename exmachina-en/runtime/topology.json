      "workspace_dir": "{{EXMACHINA_PACK_ROOT}}",
      "responsibilities": [
        "End-to-end delivery emphasizing terminology alignment, decision capture, and index structure.",
        "Schedule internal subagents and consolidate outputs as needed."
