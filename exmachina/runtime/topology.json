        "route-link-rationality"
      ]
    },
    {
      "assignment_id": "assignment-link-validation",
      "stage_name": "连结体交付 · 校验连结体",
      "agent_id": "exmachina-link-validation",
      "source_body": "校验连结体",
      "role": "owner",
      "goal": "独立完成任务交付，侧重复现、断言、证据归档与回归验证。",
      "deliverables": [
        "验证矩阵",
        "回归结果",
        "问题证据清单"
      ],
      "exit_checks": [
        "校验连结体交付已形成结构化结果。"
      ],
      "depends_on": [],
      "handoff_routes": [
        "route-link-validation"
      ]
    },
    {
      "assignment_id": "assignment-link-documentation",
      "stage_name": "连结体交付 · 文档连结体",
      "agent_id": "exmachina-link-documentation",
      "source_body": "文档连结体",
      "role": "owner",
      "goal": "独立完成任务交付，侧重盘点、结构整理、示例编写与校订发布。",
