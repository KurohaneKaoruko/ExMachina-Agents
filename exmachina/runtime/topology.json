      ],
      "depends_on": [],
      "handoff_routes": [
        "route-link-documentation"
      ]
    },
    {
      "assignment_id": "assignment-link-security",
      "stage_name": "连结体交付 · 安全连结体",
      "agent_id": "exmachina-link-security",
      "source_body": "安全连结体",
      "role": "owner",
      "goal": "独立完成任务交付，侧重威胁建模、权限审计与加固建议。",
