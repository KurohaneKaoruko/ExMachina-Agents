  "routes": [
    {
      "route_id": "route-dispatch",
      "from": "exmachina-main",
      "to": [
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ],
      "purpose": "主控体派发连结体交付与并行请求。"
    },
    {
      "route_id": "route-status",
      "from": "exmachina-main",
      "to": [
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ],
      "purpose": "状态回流与交付同步。"
    },
    {
      "route_id": "route-link-knowledge",
      "from": "exmachina-link-knowledge",
      "to": [
        "exmachina-main"
      ],
      "purpose": "知识连结体交付回流。"
    },
    {
      "route_id": "route-link-rationality",
      "from": "exmachina-link-rationality",
      "to": [
        "exmachina-main"
      ],
      "purpose": "理性连结体交付回流。"
    },
    {
      "route_id": "route-link-validation",
      "from": "exmachina-link-validation",
      "to": [
        "exmachina-main"
      ],
      "purpose": "校验连结体交付回流。"
