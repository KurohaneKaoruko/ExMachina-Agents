  "coordination_rules": [
    "必须启用子代理（subagents / sessions_spawn）。",
    "默认选择一个连结体独立完成任务；并行启用多连结体时必须说明平级分工。",
    "多智能体汇报需使用 [xx体]:xxx 格式。"
  ],
  "activation_steps": [
    "主控体读取 runtime/shared/mission-context.json、runtime/task-board.json 与 runtime/topology.json。",
    "主控体选择当前执行连结体并派发交付目标；如并行启用多连结体，说明平级分工。",
    "主控体汇总连结体产出，完成最终结构化交付。"
  ]
